# ─────────────────────────────────────────────────────────────
#  AUC Seat Watcher — environment configuration
#  Copy this file to `.env` and fill in real values.
#  NOTHING is hardcoded in the app; every secret/tunable lives here.
# ─────────────────────────────────────────────────────────────

# --- Admin page (no login; this secret IS the URL) ---
# Your admin dashboard lives at:  https://<your-host>/admin/<ADMIN_KEY>
# Keep it long and random. Generate one with: openssl rand -hex 16
ADMIN_KEY=change-me-admin-secret

# --- Banner 9 (AUC registration site) ---
# Host ONLY, no trailing slash. (You'll provide the real link.)
BANNER_BASE_URL=https://CHANGE-ME-banner-host
BANNER_PATH_PREFIX=/StudentRegistrationSsb/ssb
# Active registration term, e.g. 202710 = Spring 2027
BANNER_TERM=202710

# How often the poller checks each distinct course (minutes)
CHECK_INTERVAL_MINUTES=5

# --- Public URL of THIS app (used in links sent to users) ---
PUBLIC_BASE_URL=http://localhost:8000

# --- WhatsApp Baileys bridge (localhost only — do not expose) ---
BAILEYS_BRIDGE_URL=http://localhost:3001
BRIDGE_PORT=3001
# Shared secret between the bridge and the app (blocks webhook spoofing).
# Generate with: openssl rand -hex 24
BRIDGE_TOKEN=change-me-bridge-token
PYTHON_WEBHOOK_URL=http://localhost:8000/webhook/whatsapp
WA_SESSION_PATH=./auth_session

# --- Database ---
DATABASE_PATH=./seatwatch.db
